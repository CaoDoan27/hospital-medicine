<div class="card"><div class="card-header"><h2><i class="fas fa-file-alt"></i> Lập phiếu dự trù</h2><a href="/dieu-chuyen" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Quay lại</a></div>
<div class="card-body">
  <form action="/dieu-chuyen/luu" method="POST">
    <div class="form-group"><label>Kho nhận</label>
      <select class="form-control" name="kho_nhan_id" required><option value="">-- Chọn kho --</option>
      <% warehouses.forEach(w => { %><option value="<%= w.id %>"><%= w.ten_kho %> (<%= w.khoa || w.loai_kho %>)</option><% }) %></select></div>
    <div class="form-group"><label>Ghi chú</label><textarea class="form-control" name="ghi_chu" rows="2"></textarea></div>
    <h3 class="mb-1" style="font-size:1rem">Danh sách thuốc cần chuyển</h3>
    <table><thead><tr><th>Thuốc</th><th>Tồn kho tổng</th><th>SL yêu cầu</th><th></th></tr></thead><tbody id="items"></tbody></table>
    <button type="button" class="btn btn-outline btn-sm mt-1" onclick="addItem()"><i class="fas fa-plus"></i> Thêm</button>
    <input type="hidden" name="items" id="itemsInput">
    <div class="btn-group mt-2"><button type="submit" class="btn btn-primary" onclick="prepareItems()"><i class="fas fa-paper-plane"></i> Gửi dự trù</button></div>
  </form>
</div></div>
<script>
const drugs = <%- JSON.stringify(drugs) %>;
function addItem(){const tbody=document.getElementById('items');const tr=document.createElement('tr');let opts='<option value="">-- Chọn --</option>';drugs.forEach(d=>{opts+=`<option value="${d.id}" data-ton="${d.ton_kho_tong}">${d.ten_thuoc} (${d.ham_luong||''})</option>`;});tr.innerHTML=`<td><select class="form-control" onchange="this.closest('tr').querySelector('.ton').textContent=this.options[this.selectedIndex].dataset.ton||0">${opts}</select></td><td class="ton">0</td><td><input type="number" class="form-control sl" min="1"></td><td><button type="button" class="btn btn-sm btn-danger" onclick="this.closest('tr').remove()">×</button></td>`;tbody.appendChild(tr);}
function prepareItems(){const rows=document.querySelectorAll('#items tr');const items=[];rows.forEach(r=>{const id=r.querySelector('select').value;if(id)items.push({thuoc_id:id,so_luong:r.querySelector('.sl').value});});document.getElementById('itemsInput').value=JSON.stringify(items);}
addItem();
</script>
