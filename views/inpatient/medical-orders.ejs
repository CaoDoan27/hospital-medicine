<div class="toolbar">
  <select class="form-control" style="width:auto" onchange="window.location.href='/y-lenh?khoa='+this.value+'&ngay=<%= ngay %>'">
    <% ['Khoa Nội','Khoa Ngoại','Khoa Sản','Khoa Cấp cứu'].forEach(k => { %><option value="<%= k %>" <%= khoa===k?'selected':'' %>><%= k %></option><% }) %>
  </select>
  <input type="date" class="form-control" style="width:auto" value="<%= ngay %>" onchange="window.location.href='/y-lenh?khoa=<%= khoa %>&ngay='+this.value">
</div>
<div class="card"><div class="card-header"><h2><i class="fas fa-file-medical"></i> Y lệnh chưa tổng hợp - <%= khoa %></h2><span class="badge badge-info"><%= orders.length %> y lệnh</span></div>
<div class="card-body">
  <% if (!orders.length) { %><div class="empty-state"><i class="fas fa-check-circle"></i><p>Không có y lệnh chờ tổng hợp</p></div><% } else { %>
  <form action="/y-lenh/tong-hop" method="POST">
    <input type="hidden" name="khoa" value="<%= khoa %>">
    <table><thead><tr><th><input type="checkbox" id="checkAll" onchange="document.querySelectorAll('.yl-check').forEach(c=>c.checked=this.checked)"></th><th>Bệnh nhân</th><th>Thuốc</th><th>SL</th><th>Liều dùng</th><th>Buổi</th><th>BS chỉ định</th></tr></thead>
    <tbody><% orders.forEach(o => { %><tr><td><input type="checkbox" name="selected_orders" value="<%= o.id %>" class="yl-check"></td>
      <td><strong><%= o.ho_ten %></strong></td><td><%= o.ten_thuoc %> (<%= o.ham_luong %>)</td><td><%= o.so_luong %> <%= o.don_vi_tinh %></td>
      <td><%= o.lieu_dung %></td><td><%= o.buoi %></td><td><%= o.bac_si_chi_dinh %></td></tr><% }) %></tbody></table>
    <div class="btn-group mt-2"><button type="submit" class="btn btn-primary"><i class="fas fa-layer-group"></i> Tổng hợp & Tạo phiếu lĩnh</button></div>
  </form><% } %>
</div></div>
<div class="card mt-2"><div class="card-header"><h2><i class="fas fa-history"></i> Phiếu lĩnh gần đây</h2></div>
<div class="card-body" style="padding:0"><table><thead><tr><th>Mã PL</th><th>Khoa</th><th>Người lập</th><th>Ngày</th><th>Trạng thái</th></tr></thead>
<tbody><% phieuLinh.forEach(p => { %><tr><td>PL-<%= p.id %></td><td><%= p.khoa %></td><td><%= p.nguoi_lap %></td><td><%= new Date(p.ngay_lap).toLocaleString('vi-VN') %></td>
<td><span class="badge <%= p.trang_thai==='da_cap_phat'?'badge-success':'badge-warning' %>"><%= p.trang_thai==='da_cap_phat'?'Đã cấp phát':'Chờ duyệt' %></span></td></tr><% }) %></tbody></table></div></div>
