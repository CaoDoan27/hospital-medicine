<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-warehouse"></i> Phiếu nhập kho</h2>
    <a href="/nhap-kho/tao" class="btn btn-primary" data-shortcut="new"><i class="fas fa-plus"></i> Tạo phiếu nhập (F2)</a>
  </div>
  <div class="card-body" style="padding:0">
    <div class="table-wrapper"><table>
      <thead><tr><th>#</th><th>Số HĐ</th><th>Nhà cung cấp</th><th>Kho nhập</th><th>Ngày lập</th><th>Tổng tiền</th><th>Người lập</th><th>Thao tác</th></tr></thead>
      <tbody>
      <% if (receipts.length === 0) { %><tr><td colspan="8" class="text-center text-muted" style="padding:30px">Chưa có phiếu nhập kho</td></tr><% } %>
      <% receipts.forEach((r, i) => { %>
        <tr><td><%= i+1 %></td><td><strong><%= r.so_hoa_don %></strong></td><td><%= r.ten_nha_cung_cap %></td><td><%= r.ten_kho %></td>
        <td><%= new Date(r.ngay_lap).toLocaleDateString('vi-VN') %></td>
        <td class="text-right"><%= new Intl.NumberFormat('vi-VN').format(r.tong_tien) %>đ</td><td><%= r.nguoi_lap %></td>
        <td><button class="btn btn-sm btn-info" onclick="viewDetails(<%= r.id %>)"><i class="fas fa-eye"></i> Chi tiết</button></td></tr>
      <% }) %>
      </tbody>
    </table></div>
  </div>
</div>

<!-- Modal Chi tiết -->
<div id="receiptDetailModal" class="modal" tabindex="-1" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999999; align-items: center; justify-content: center;">
  <div class="modal-dialog" style="width: 100%; max-width: 800px; background: #fff; border-radius: 8px; overflow: hidden; position: relative; box-shadow: 0 4px 15px rgba(0,0,0,0.2); margin: 0;">
    <div class="modal-header" style="padding: 15px; border-bottom: 1px solid #ddd; display: flex; justify-content: space-between; align-items: center;">
      <h5 class="modal-title" style="margin:0;">Chi tiết phiếu nhập</h5>
      <button type="button" class="close" onclick="closeModal()" style="border:none; background:none; font-size:24px; cursor:pointer;">&times;</button>
    </div>
    <div class="modal-body" style="padding: 15px; max-height: calc(100vh - 200px); overflow-y: auto;">
      <table style="width: 100%; border-collapse: collapse; margin-bottom: 0;">
        <thead>
          <tr style="background: #f8f9fa;">
            <th style="padding: 8px; border: 1px solid #ddd;">Tên thuốc</th>
            <th style="padding: 8px; border: 1px solid #ddd;">ĐVT</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Số lô</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Hạn dùng</th>
            <th style="padding: 8px; border: 1px solid #ddd; text-align:right">Số lượng</th>
            <th style="padding: 8px; border: 1px solid #ddd; text-align:right">Đơn giá</th>
            <th style="padding: 8px; border: 1px solid #ddd; text-align:right">Thành tiền</th>
          </tr>
        </thead>
        <tbody id="detailTableBody">
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
async function viewDetails(id) {
  try {
    const modal = document.getElementById('receiptDetailModal');
    if (modal.parentNode !== document.body) {
      document.body.appendChild(modal);
    }
    const res = await fetch(`/nhap-kho/api/chi-tiet/${id}`);
    const result = await res.json();
    if (!result.success) throw new Error(result.error);
    const tbody = document.getElementById('detailTableBody');
    tbody.innerHTML = '';
    result.data.forEach(item => {
      const hanDung = new Date(item.han_dung).toLocaleDateString('vi-VN');
      const soLuong = new Intl.NumberFormat('vi-VN').format(item.so_luong);
      const donGia = new Intl.NumberFormat('vi-VN').format(item.don_gia || 0);
      const thanhTien = new Intl.NumberFormat('vi-VN').format(item.thanh_tien || 0);
      const row = `<tr>
        <td style="padding: 8px; border: 1px solid #ddd;">${item.ten_thuoc}</td>
        <td style="padding: 8px; border: 1px solid #ddd;">${item.don_vi_tinh}</td>
        <td style="padding: 8px; border: 1px solid #ddd;">${item.so_lo}</td>
        <td style="padding: 8px; border: 1px solid #ddd;">${hanDung}</td>
        <td style="padding: 8px; border: 1px solid #ddd; text-align:right">${soLuong}</td>
        <td style="padding: 8px; border: 1px solid #ddd; text-align:right">${donGia}</td>
        <td style="padding: 8px; border: 1px solid #ddd; text-align:right">${thanhTien}</td>
      </tr>`;
      tbody.insertAdjacentHTML('beforeend', row);
    });
    document.getElementById('receiptDetailModal').style.display = 'flex';
  } catch (err) {
    alert('Lỗi tải chi tiết: ' + err.message);
  }
}
function closeModal() {
  document.getElementById('receiptDetailModal').style.display = 'none';
}
</script>
